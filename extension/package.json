{
  "name": "guardi-image-shield",
  "version": "0.1.0",
  "description": "Guardi image shield — blurs inappropriate images in the browser, on-device.",
  "private": true,
  "type": "module",
  "scripts": {
    "download-models": "node scripts/download-models.mjs",
    "prebuild": "node scripts/download-models.mjs",
    "prebuild:chromium": "node scripts/download-models.mjs",
    "prebuild:firefox": "node scripts/download-models.mjs",
    "build": "npm run build:chromium && npm run build:firefox",
    "build:chromium": "node esbuild.config.mjs chromium",
    "build:firefox": "node esbuild.config.mjs firefox",
    "zip:chromium": "node scripts/zip-chromium.mjs",
    "pack:host": "node scripts/pack-host.mjs",
    "serve:host": "node scripts/serve-host.mjs",
    "sign:firefox": "node scripts/sign-firefox.mjs",
    "prepare:firefox-release": "node scripts/prepare-firefox-release.mjs",
    "publish:firefox": "node scripts/publish-firefox.mjs",
    "release:firefox": "node scripts/release-firefox.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "buffer": "^6.0.3",
    "nsfwjs": "^4.2.1"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "crx3": "^1.1.3",
    "esbuild": "^0.24.0"
  }
}
