<Window x:Class="EduGuardAgent.Views.SubNamePromptWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Guardi"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        ShowInTaskbar="False">
    <Border Background="{StaticResource CardBrush}"
            CornerRadius="20"
            Padding="32,28"
            MinWidth="400"
            MaxWidth="460"
            BorderBrush="{StaticResource SkyBorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#0369A1"
                              BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.35" />
        </Border.Effect>

        <StackPanel>
            <views:GuardiMascot x:Name="Mascot"
                                Width="72" Height="82"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,12" />

            <TextBlock x:Name="TitleText"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryDarkBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />

            <TextBlock x:Name="PromptText"
                       FontSize="15"
                       Foreground="{StaticResource MutedBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,10,0,16" />

            <TextBox x:Name="NameInput"
                     MaxLength="32"
                     FontSize="20"
                     Padding="12,10"
                     HorizontalContentAlignment="Center"
                     Margin="0,0,0,8"
                     KeyDown="OnNameKeyDown" />

            <TextBlock x:Name="ErrorText"
                       Foreground="{StaticResource WarningBrush}"
                       FontSize="13"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MinHeight="20"
                       Margin="0,0,0,16"
                       Visibility="Collapsed" />

            <Button x:Name="ConfirmButton"
                    Style="{StaticResource PrimaryButton}"
                    Click="OnConfirmClick"
                    Padding="28,12"
                    FontSize="14"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
