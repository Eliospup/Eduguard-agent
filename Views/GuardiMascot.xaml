<UserControl x:Class="EduGuardAgent.Views.GuardiMascot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             SnapsToDevicePixels="True">
    <Grid>
      <Viewbox x:Name="VectorFallback" Stretch="Uniform"
             Width="{Binding ElementName=Root, Path=Width}"
             Height="{Binding ElementName=Root, Path=Height}">
        <Canvas Width="120" Height="136">
            <Ellipse Canvas.Left="28" Canvas.Top="122" Width="64" Height="10" Fill="#22000000" />

            <Path Fill="#0EA5E9"
                  Data="M60,8 L104,30 L104,78 Q104,118 60,132 Q16,118 16,78 L16,30 Z" />
            <Path Fill="#7DD3FC" Opacity="0.35"
                  Data="M60,14 L96,32 L96,76 Q96,108 60,120 Q24,108 24,76 L24,32 Z" />

            <Ellipse Canvas.Left="78" Canvas.Top="18" Width="28" Height="28" Fill="#FFFFFF" />
            <TextBlock Canvas.Left="84" Canvas.Top="23"
                       Text="✓"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="#0284C7" />

            <Ellipse Canvas.Left="40" Canvas.Top="50" Width="16" Height="18" Fill="White" />
            <Ellipse Canvas.Left="64" Canvas.Top="50" Width="16" Height="18" Fill="White" />
            <Ellipse Canvas.Left="46" Canvas.Top="57" Width="7" Height="7" Fill="#0C4A6E" />
            <Ellipse Canvas.Left="70" Canvas.Top="57" Width="7" Height="7" Fill="#0C4A6E" />
            <Ellipse Canvas.Left="48" Canvas.Top="55" Width="3" Height="3" Fill="White" />
            <Ellipse Canvas.Left="72" Canvas.Top="55" Width="3" Height="3" Fill="White" />

            <Ellipse Canvas.Left="32" Canvas.Top="68" Width="12" Height="7" Fill="#BAE6FD" Opacity="0.8" />
            <Ellipse Canvas.Left="76" Canvas.Top="68" Width="12" Height="7" Fill="#BAE6FD" Opacity="0.8" />

            <Path Stroke="White"
                  StrokeThickness="3.5"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Data="M42,79 Q60,97 78,79" />
        </Canvas>
      </Viewbox>
      <Image x:Name="PngImage" Stretch="Uniform" Visibility="Collapsed" />
    </Grid>
</UserControl>
