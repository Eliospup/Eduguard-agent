<UserControl x:Class="EduGuardAgent.Views.LocalSections.AppearanceSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prof="clr-namespace:EduGuardAgent.Profiles"
             xmlns:views="clr-namespace:EduGuardAgent.Views">
  <Border Style="{StaticResource LocalSectionBox}">
    <StackPanel>
      <TextBlock Text="On-screen visuals" Style="{StaticResource LocalSectionLabel}" />
      <TextBlock Text="Hide Guardi's visible surfaces. Nothing is un-enforced — timers still tick, sites are still filtered — only the on-screen chrome is hidden. Applies to every mode."
                 Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14" />

      <views:SettingRow Label="Desktop widget" Description="The little floating Guardi badge on the desktop.">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalShowDesktopWidget}" />
      </views:SettingRow>
      <views:SettingRow Label="{x:Static prof:LocalModeCopy.WidgetRemindersTitle}"
                        Description="{x:Static prof:LocalModeCopy.WidgetRemindersHint}">
        <CheckBox Style="{StaticResource ToggleSwitch}"
                  IsChecked="{Binding LocalWidgetRemindersEnabled}"
                  IsEnabled="{Binding LocalShowDesktopWidget}" />
      </views:SettingRow>
      <StackPanel Margin="0,0,0,12">
        <TextBlock Text="{x:Static prof:LocalModeCopy.WidgetRemindersFrequencyLabel}" Style="{StaticResource LocalSectionLabel}" />
        <TextBox Text="{Binding LocalWidgetReminderFrequencyMinutes, UpdateSourceTrigger=PropertyChanged}"
                 Width="120" HorizontalAlignment="Left" IsEnabled="{Binding LocalWidgetRemindersEnabled}" />
      </StackPanel>

      <Separator Margin="0,2,0,12" />

      <views:SettingRow Label="Game time countdown" Description="The little timer overlay while a game is running.">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalShowGamingTimer}" />
      </views:SettingRow>
      <views:SettingRow Label="YouTube time countdown" Description="The little timer overlay while watching YouTube.">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalShowYoutubeTimer}" />
      </views:SettingRow>

      <Separator Margin="0,2,0,12" />

      <views:SettingRow Label="Guardi new-tab page" Description="The Guardi-styled new tab in the browser. Off shows the plain browser new tab.">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalStyledNewTabPage}" />
      </views:SettingRow>
      <views:SettingRow Label="Badge on websites" Description="The little Guardi indicator shown on web pages.">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalShowWebsiteBadge}" />
      </views:SettingRow>

      <TextBlock Text="The new-tab page and website badge live in the browser extension — they update shortly after saving, once the browser picks up the change."
                 Foreground="{DynamicResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12" />

      <Separator Margin="0,2,0,14" />

      <TextBlock Text="Sub nickname" Style="{StaticResource LocalSectionLabel}" />
      <TextBlock Text="Used in greetings, like &quot;Hi, {name}!&quot;. Leave blank to keep the current one."
                 Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6" />
      <TextBox Text="{Binding LocalSubDisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" />
    </StackPanel>
  </Border>
</UserControl>
