<UserControl x:Class="EduGuardAgent.Views.LocalSections.BedtimeSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prof="clr-namespace:EduGuardAgent.Profiles"
             xmlns:views="clr-namespace:EduGuardAgent.Views">
  <StackPanel>
    <Border Style="{StaticResource LocalSectionBox}">
      <StackPanel>
        <views:SettingRow Label="{x:Static prof:LocalModeCopy.BedtimeEnabled}"
                          Description="Lock the computer overnight so it's time to sleep.">
          <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalBedtimeEnabled}" />
        </views:SettingRow>
        <views:SettingRow Label="Schedule" Description="From bedtime until wake-up.">
          <StackPanel Orientation="Horizontal">
            <views:TimeField Time="{Binding LocalBedtimeTime, Mode=TwoWay}" />
            <TextBlock Text="→" VerticalAlignment="Center" Margin="10,0" Foreground="{DynamicResource MutedBrush}" />
            <views:TimeField Time="{Binding LocalWakeTime, Mode=TwoWay}" />
          </StackPanel>
        </views:SettingRow>
        <views:SettingRow Label="{x:Static prof:LocalModeCopy.BlueLightFilterEnabled}"
                          Description="Warm the screen before bedtime.">
          <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalBlueLightFilterEnabled}" />
        </views:SettingRow>
      </StackPanel>
    </Border>
    <Border Style="{StaticResource LocalSectionBox}">
      <StackPanel>
        <TextBlock Text="{x:Static prof:LocalModeCopy.BedtimeWeeklyTitle}" Style="{StaticResource LocalSectionLabel}" />
        <TextBlock Text="{x:Static prof:LocalModeCopy.BedtimeWeeklyHint}"
                   Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6" />
        <ItemsControl ItemsSource="{Binding LocalBedtimeWeekly}" ItemTemplate="{StaticResource LocalWeeklyBedtimeDayTemplate}" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
