<UserControl x:Class="EduGuardAgent.Views.LocalSections.ScreenTimeSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:EduGuardAgent.Views">
  <StackPanel>
    <Border Style="{StaticResource LocalSectionBox}">
      <StackPanel>
        <TextBlock Text="Screen time — minutes per day" Style="{StaticResource LocalSectionLabel}" />
        <views:MinuteStepper Minutes="{Binding LocalScreenTimeMinutes, Mode=TwoWay}" Step="15" Max="1440" HorizontalAlignment="Left" />
      </StackPanel>
    </Border>
    <Border Style="{StaticResource LocalSectionBox}">
      <StackPanel>
        <TextBlock Text="Weekly overrides — minutes per day" Style="{StaticResource LocalSectionLabel}" />
        <TextBlock Text="Optional. Toggle a day to override the daily limit."
                   Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6" />
        <ItemsControl ItemsSource="{Binding LocalScreenWeekly}" ItemTemplate="{StaticResource LocalWeeklyDayTemplate}" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
