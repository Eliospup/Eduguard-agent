<UserControl x:Class="EduGuardAgent.Views.LocalSections.StudySection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prof="clr-namespace:EduGuardAgent.Profiles"
             xmlns:views="clr-namespace:EduGuardAgent.Views">
  <StackPanel>
    <Border Style="{StaticResource LocalSectionBox}">
      <StackPanel>
        <views:SettingRow Label="{x:Static prof:LocalModeCopy.StudyEnabled}"
                          Description="Block distractions during study hours.">
          <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalStudyEnabled}" />
        </views:SettingRow>
        <views:SettingRow Label="Study hours" Description="From start until end.">
          <StackPanel Orientation="Horizontal">
            <views:TimeField Time="{Binding LocalStudyStart, Mode=TwoWay}" />
            <TextBlock Text="→" VerticalAlignment="Center" Margin="10,0" Foreground="{DynamicResource MutedBrush}" />
            <views:TimeField Time="{Binding LocalStudyEnd, Mode=TwoWay}" />
          </StackPanel>
        </views:SettingRow>
        <TextBlock Text="{x:Static prof:LocalModeCopy.StudyDays}" Style="{StaticResource LocalSectionLabel}" />
        <TextBlock Text="Fallback days when a weekday has no override."
                   Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6" />
        <views:DayChips Days="{Binding LocalStudyDaysText, Mode=TwoWay}" Margin="0,0,0,16" HorizontalAlignment="Left" />

        <TextBlock Text="During study hours" Style="{StaticResource LocalSectionLabel}" />
        <views:SettingRow Label="{x:Static prof:LocalModeCopy.StudyBlockGames}">
          <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalStudyBlockGames}" />
        </views:SettingRow>
        <views:SettingRow Label="{x:Static prof:LocalModeCopy.StudyBlockYoutube}">
          <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalStudyBlockYoutube}" />
        </views:SettingRow>
        <views:SettingRow Label="{x:Static prof:LocalModeCopy.StudyBlockDistractingSites}">
          <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalStudyBlockDistractingSites}" />
        </views:SettingRow>
        <views:SettingRow Label="{x:Static prof:LocalModeCopy.StudyBlockDistractingApps}">
          <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalStudyBlockDistractingApps}" />
        </views:SettingRow>
      </StackPanel>
    </Border>
    <Border Style="{StaticResource LocalSectionBox}">
      <StackPanel>
        <TextBlock Text="{x:Static prof:LocalModeCopy.StudyWeeklyTitle}" Style="{StaticResource LocalSectionLabel}" />
        <TextBlock Text="{x:Static prof:LocalModeCopy.StudyWeeklyHint}"
                   Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6" />
        <ItemsControl ItemsSource="{Binding LocalStudyWeekly}" ItemTemplate="{StaticResource LocalWeeklyStudyDayTemplate}" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
