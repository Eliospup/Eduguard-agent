<UserControl x:Class="EduGuardAgent.Views.LocalSections.SystemLocksSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:EduGuardAgent.Views">
  <Border Style="{StaticResource LocalSectionBox}">
    <StackPanel>
      <TextBlock Text="Block system tools" Style="{StaticResource LocalSectionLabel}" Margin="0,0,0,4" />
      <TextBlock Text="Stop the child reaching Windows tools they could use to weaken Guardi."
                 Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
      <views:SettingRow Label="Block Task Manager">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalBlockTaskManager}" />
      </views:SettingRow>
      <views:SettingRow Label="VPN shield" Description="Close VPN apps that could tunnel around filtering.">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalVpnShield}" />
      </views:SettingRow>
      <views:SettingRow Label="Block Registry Editor">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalBlockRegistryEditor}" />
      </views:SettingRow>
      <views:SettingRow Label="Block Command Prompt">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalBlockCommandPrompt}" />
      </views:SettingRow>
      <views:SettingRow Label="Block PowerShell">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalBlockPowerShell}" />
      </views:SettingRow>
      <views:SettingRow Label="Block system config tools">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalBlockSystemConfig}" />
      </views:SettingRow>
      <views:SettingRow Label="Block Control Panel">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalBlockControlPanel}" />
      </views:SettingRow>
      <views:SettingRow Label="Block process tools">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalBlockProcessTools}" />
      </views:SettingRow>
      <views:SettingRow Label="Block auto process killers" Description="Stop tools that kill Guardi by name on a loop.">
        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding LocalBlockProcessKillers}" />
      </views:SettingRow>
    </StackPanel>
  </Border>
</UserControl>
