<Window x:Class="EduGuardAgent.Views.GamingHudOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Play time"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">
    <Border x:Name="HudBorder"
            Background="{StaticResource CardBrush}"
            CornerRadius="8"
            Padding="9,7"
            MinWidth="152"
            MaxWidth="188"
            BorderBrush="{StaticResource SkyBorderBrush}"
            BorderThickness="1"
            Opacity="0.92">
        <Border.Effect>
            <DropShadowEffect Color="#0369A1"
                              BlurRadius="10"
                              ShadowDepth="2"
                              Opacity="0.22" />
        </Border.Effect>

        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedBrush}" />

                    <TextBlock Text="·"
                               FontSize="9"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="4,0" />

                    <TextBlock x:Name="GameNameText"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryDarkBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="72" />
                </StackPanel>

                <TextBlock x:Name="CountdownText"
                           Grid.Column="1"
                           FontSize="17"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           FontFamily="Consolas, Cascadia Mono, Segoe UI, monospace"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </Grid>

            <ProgressBar x:Name="ProgressBar"
                         Maximum="100"
                         Height="3"
                         Margin="0,6,0,0"
                         Foreground="{StaticResource PrimaryBrush}"
                         Background="{StaticResource SkyBorderBrush}"
                         BorderThickness="0" />
        </StackPanel>
    </Border>
</Window>
