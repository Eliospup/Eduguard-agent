<Window x:Class="EduGuardAgent.Views.SelfLockConfirmWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Activate self-lock"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False">
    <Grid Background="#B0141B2D">
        <Border Background="{StaticResource CardBrush}"
                CornerRadius="24"
                Padding="36,32"
                MaxWidth="560"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                BorderBrush="{StaticResource SkyBorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#0369A1"
                                  BlurRadius="28"
                                  ShadowDepth="0"
                                  Opacity="0.35" />
            </Border.Effect>

            <StackPanel>
                <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
                    <views:GuardiMascot x:Name="Mascot" Width="96" Height="110" />
                    <views:TrustedSubMascot x:Name="TrustedSubMascotIcon" Width="96" Height="110" />
                    <views:RestrictedSubMascot x:Name="RestrictedSubMascotIcon" Width="96" Height="110" />
                </Grid>

                <TextBlock x:Name="TitleText"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryDarkBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />

                <Border Background="{StaticResource HomeSurfaceBrush}"
                        BorderBrush="{StaticResource HomeSurfaceBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20,18"
                        Margin="0,20,0,16">
                    <StackPanel>
                        <TextBlock x:Name="MessageText"
                                   FontSize="18"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   LineHeight="26" />
                        <Border Background="#1FE11D48"
                                BorderBrush="#E11D48"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16,12"
                                Margin="0,16,0,0">
                            <TextBlock x:Name="WarningText"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#BE123C"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       LineHeight="20" />
                        </Border>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button x:Name="CancelButton"
                            Style="{StaticResource PrimaryButton}"
                            Click="OnCancelClick"
                            IsCancel="True"
                            Padding="24,14"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Margin="0,0,12,0" />
                    <Button x:Name="ConfirmButton"
                            Style="{StaticResource SubtleButton}"
                            Click="OnConfirmClick"
                            Padding="24,14"
                            FontSize="15"
                            FontWeight="SemiBold" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
