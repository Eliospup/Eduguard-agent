<Window x:Class="EduGuardAgent.Views.ExtensionInstallOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Guardi Shield"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        Background="{StaticResource LockOverlayGradient}">
    <Grid VerticalAlignment="Center"
          HorizontalAlignment="Center"
          MaxWidth="640"
          Margin="40,32">
        <StackPanel>
            <views:GuardiMascot Width="140"
                                Height="160"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,28" />

            <TextBlock x:Name="HeadlineText"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="{StaticResource OnPrimaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       LineHeight="44"
                       Margin="0,0,0,16" />

            <TextBlock x:Name="BodyText"
                       FontSize="20"
                       Foreground="{StaticResource OnPrimaryMutedBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       LineHeight="30"
                       MaxWidth="520"
                       HorizontalAlignment="Center" />

            <Button x:Name="DevSkipButton"
                    Content="Skip for now (dev testing)"
                    Style="{StaticResource GhostButton}"
                    Click="OnDevSkipClicked"
                    Margin="0,36,0,0"
                    Padding="20,10"
                    FontSize="13"
                    Foreground="{StaticResource OnPrimaryMutedBrush}"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</Window>
