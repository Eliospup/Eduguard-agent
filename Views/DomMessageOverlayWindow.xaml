<Window x:Class="EduGuardAgent.Views.DomMessageOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Message from your Dom"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False">
    <Grid Background="#990C4A6E">
        <Border Background="{StaticResource CardBrush}"
                CornerRadius="24"
                Padding="36,32"
                MaxWidth="560"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                BorderBrush="{StaticResource SkyBorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#0369A1"
                                  BlurRadius="28"
                                  ShadowDepth="0"
                                  Opacity="0.35" />
            </Border.Effect>

            <StackPanel>
                <views:GuardiMascot x:Name="Mascot"
                                    Width="96" Height="110"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,16" />

                <TextBlock x:Name="TitleText"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryDarkBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />

                <Border Background="{StaticResource AccentBrush}"
                        CornerRadius="16"
                        Padding="20,18"
                        Margin="0,20,0,28">
                    <TextBlock x:Name="MessageText"
                               FontSize="18"
                               Foreground="{StaticResource TextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               LineHeight="26" />
                </Border>

                <Button x:Name="DismissButton"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnDismissClick"
                        HorizontalAlignment="Center"
                        Padding="32,14"
                        FontSize="16"
                        FontWeight="SemiBold" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
