<UserControl x:Class="EduGuardAgent.Views.TrustedSubMascot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             SnapsToDevicePixels="True">
    <Grid>
      <Viewbox x:Name="VectorFallback" Stretch="Uniform"
             Width="{Binding ElementName=Root, Path=Width}"
             Height="{Binding ElementName=Root, Path=Height}">
        <Canvas Width="120" Height="136">
            <Ellipse Canvas.Left="28" Canvas.Top="122" Width="64" Height="10" Fill="#22000000" />

            <!-- Main body: rounded square, school-satchel proportions -->
            <Rectangle Canvas.Left="14" Canvas.Top="36" Width="92" Height="88" RadiusX="36" RadiusY="36" Fill="#33E6CD" />

            <!-- Side pocket -->
            <Rectangle Canvas.Left="4" Canvas.Top="66" Width="26" Height="48" RadiusX="13" RadiusY="13" Fill="#1FA897" />
            <Path Stroke="#11202A" StrokeThickness="2" Opacity="0.4" Data="M17,74 L17,108" />

            <!-- Top zipper pull + center zip line -->
            <Ellipse Canvas.Left="55" Canvas.Top="28" Width="10" Height="10" Fill="#11202A" Opacity="0.5" />
            <Path Stroke="#11202A" StrokeThickness="2" Opacity="0.35" Data="M60,38 L60,58" />
            <Path Stroke="#11202A" StrokeThickness="2" Opacity="0.35" Data="M60,116 L60,122" />

            <!-- Graduation cap -->
            <Path Stroke="#E8B84B" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M60,26 L39,16" />
            <Ellipse Canvas.Left="34" Canvas.Top="10" Width="9" Height="11" Fill="#E8B84B" />
            <Path Fill="#1B1B1F" Data="M28,30 L60,14 L92,30 L60,46 Z" />
            <Rectangle Canvas.Left="45" Canvas.Top="32" Width="30" Height="12" RadiusX="3" RadiusY="3" Fill="#1B1B1F" />
            <Ellipse Canvas.Left="57" Canvas.Top="24" Width="7" Height="7" Fill="#1B1B1F" />

            <!-- Face -->
            <Ellipse Canvas.Left="34" Canvas.Top="64" Width="22" Height="26" Fill="White" />
            <Ellipse Canvas.Left="64" Canvas.Top="64" Width="22" Height="26" Fill="White" />
            <Ellipse Canvas.Left="40" Canvas.Top="72" Width="11" Height="11" Fill="#11202A" />
            <Ellipse Canvas.Left="70" Canvas.Top="72" Width="11" Height="11" Fill="#11202A" />
            <Ellipse Canvas.Left="43" Canvas.Top="74" Width="4" Height="4" Fill="White" />
            <Ellipse Canvas.Left="73" Canvas.Top="74" Width="4" Height="4" Fill="White" />

            <Ellipse Canvas.Left="28" Canvas.Top="88" Width="12" Height="7" Fill="#0F1822" Opacity="0.18" />
            <Ellipse Canvas.Left="80" Canvas.Top="88" Width="12" Height="7" Fill="#0F1822" Opacity="0.18" />

            <Path Fill="#11202A" Data="M42,94 Q60,118 78,94 Q69,104 60,104 Q51,104 42,94 Z" />
            <Ellipse Canvas.Left="50" Canvas.Top="96" Width="10" Height="5" Fill="White" Opacity="0.45" />
        </Canvas>
      </Viewbox>
      <Image x:Name="PngImage" Stretch="Uniform" Visibility="Collapsed" />
    </Grid>
</UserControl>
