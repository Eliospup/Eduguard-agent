<UserControl x:Class="EduGuardAgent.Views.GuardiLockedShieldIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             SnapsToDevicePixels="True">
    <Viewbox Stretch="Uniform"
             Width="{Binding ElementName=Root, Path=Width}"
             Height="{Binding ElementName=Root, Path=Height}">
        <Canvas Width="120" Height="136">
            <Ellipse Canvas.Left="28" Canvas.Top="122" Width="64" Height="10" Fill="#22000000" />

            <Path Fill="{DynamicResource PrimaryBrush}"
                  Data="M60,8 L104,30 L104,78 Q104,118 60,132 Q16,118 16,78 L16,30 Z" />
            <Path Fill="{DynamicResource AccentBrush}" Opacity="0.35"
                  Data="M60,14 L96,32 L96,76 Q96,108 60,120 Q24,108 24,76 L24,32 Z" />

            <Path Fill="#F59E0B"
                  Stroke="#B45309"
                  StrokeThickness="1.5"
                  Data="M48,54 C48,46 54,40 60,40 C66,40 72,46 72,54 L72,58 L48,58 Z" />
            <Rectangle Canvas.Left="46" Canvas.Top="56" Width="28" Height="24" RadiusX="4" RadiusY="4"
                       Fill="#F59E0B" Stroke="#B45309" StrokeThickness="1.5" />
            <Ellipse Canvas.Left="56" Canvas.Top="64" Width="8" Height="8" Fill="#1E3A8A" />
            <Path Fill="#1E3A8A"
                  Data="M58,70 L62,70 L61,76 L59,76 Z" />
        </Canvas>
    </Viewbox>
</UserControl>
