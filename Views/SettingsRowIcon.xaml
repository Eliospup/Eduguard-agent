<UserControl x:Class="EduGuardAgent.Views.SettingsRowIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="48"
             Height="40"
             SnapsToDevicePixels="True">
    <Border Width="40"
            Height="40"
            CornerRadius="16"
            Background="#E8F4FF"
            BorderBrush="{StaticResource GlassBorderBrush}"
            BorderThickness="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Center">
        <Viewbox Width="22"
                 Height="22"
                 Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <TextBlock Text="{Binding Glyph, ElementName=Root}"
                       Foreground="{StaticResource PrimaryDarkBrush}"
                       FontFamily="Segoe UI Emoji, Segoe UI Symbol, Segoe UI"
                       FontSize="20"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Viewbox>
    </Border>
</UserControl>
