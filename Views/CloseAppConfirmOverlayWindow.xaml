<Window x:Class="EduGuardAgent.Views.CloseAppConfirmOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Quit EduGuard"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False">
    <Grid Background="#B0141B2D">
        <Border Background="{StaticResource CardBrush}"
                CornerRadius="24"
                Padding="36,32"
                MaxWidth="560"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                BorderBrush="{StaticResource SkyBorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#0369A1"
                                  BlurRadius="28"
                                  ShadowDepth="0"
                                  Opacity="0.35" />
            </Border.Effect>

            <StackPanel>
                <views:GuardiMascot x:Name="Mascot"
                                    Width="96" Height="110"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,16" />

                <TextBlock x:Name="TitleText"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryDarkBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />

                <Border Background="{StaticResource HomeSurfaceBrush}"
                        BorderBrush="{StaticResource HomeSurfaceBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20,18"
                        Margin="0,20,0,16">
                    <TextBlock x:Name="MessageText"
                               FontSize="18"
                               Foreground="{StaticResource TextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               LineHeight="26" />
                </Border>

                <TextBlock x:Name="HintText"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,24" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="StayButton"
                            Style="{StaticResource PrimaryButton}"
                            Click="OnStayClick"
                            Padding="24,14"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Margin="0,0,12,0" />
                    <Button x:Name="QuitButton"
                            Style="{StaticResource SubtleButton}"
                            Click="OnQuitClick"
                            Padding="24,14"
                            FontSize="15"
                            FontWeight="SemiBold" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
