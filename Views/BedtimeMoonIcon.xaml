            <Ellipse Canvas.Left="10" Canvas.Top="10" Width="100" Height="100" Fill="#BAE6FD" Opacity="0.35" />

            <Path Fill="#0EA5E9"
                  Data="M60,14 C34,14 14,34 14,60 C14,86 34,106 60,106 C78,106 92,96 100,80 C84,84 70,82 58,70 C42,54 42,30 60,14 Z" />

            <Path Fill="#7DD3FC" Opacity="0.45"
                  Data="M60,22 C40,22 24,38 24,58 C24,72 32,84 44,90 C38,78 38,62 48,50 C54,42 56,30 60,22 Z" />

            <Ellipse Canvas.Left="78" Canvas.Top="24" Width="10" Height="10" Fill="#FFFFFF" Opacity="0.85" />
            <Ellipse Canvas.Left="34" Canvas.Top="44" Width="6" Height="6" Fill="#FFFFFF" Opacity="0.65" />
            <Ellipse Canvas.Left="88" Canvas.Top="58" Width="5" Height="5" Fill="#FFFFFF" Opacity="0.55" />
