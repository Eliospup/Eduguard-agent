<Window x:Class="EduGuardAgent.Views.WelcomeTourWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Guardi"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        Closing="OnClosing"
        Background="{DynamicResource PageGradient}">
    <Grid>
        <Border x:Name="CardBorder"
                Background="{DynamicResource CardBrush}"
                CornerRadius="24"
                Padding="40,34"
                MaxWidth="580"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{DynamicResource SkyBorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#0369A1"
                                  BlurRadius="32"
                                  ShadowDepth="0"
                                  Opacity="0.35" />
            </Border.Effect>

            <StackPanel>
                <Grid HorizontalAlignment="Center" Margin="0,0,0,14">
                    <views:GuardiMascot x:Name="GuardiIcon" Width="84" Height="96" />
                    <views:TrustedSubMascot x:Name="TrustedSubIcon" Width="84" Height="96" Visibility="Collapsed" />
                    <views:RestrictedSubMascot x:Name="RestrictedSubIcon" Width="84" Height="96" Visibility="Collapsed" />
                </Grid>

                <TextBlock x:Name="KickerText"
                           FontSize="12"
                           FontWeight="Bold"
                           Foreground="{DynamicResource MutedBrush}"
                           TextAlignment="Center"
                           Visibility="Collapsed"
                           Margin="0,0,0,2" />

                <TextBlock x:Name="TitleText"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryDarkBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="BodyText"
                           FontSize="15"
                           Foreground="{DynamicResource MutedBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           Margin="0,14,0,18" />

                <!-- Trust meter illustrative bar — only visible on the trust page. -->
                <StackPanel x:Name="TrustBarPanel" Visibility="Collapsed" Margin="0,0,0,18">
                    <Border CornerRadius="999" Height="14" ClipToBounds="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55*" />
                                <ColumnDefinition Width="30*" />
                                <ColumnDefinition Width="15*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#22C55E" />
                            <Border Grid.Column="1" Background="#F59E0B" />
                            <Border Grid.Column="2" Background="#EF4444" />
                        </Grid>
                    </Border>
                    <Grid Margin="2,6,2,0">
                        <TextBlock x:Name="TrustFullLabelText"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Left" />
                        <TextBlock x:Name="TrustLowLabelText"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedBrush}"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>

                <!-- Progress dots -->
                <StackPanel x:Name="ProgressDots" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                    <Ellipse x:Name="Dot0" Width="8" Height="8" Margin="4,0" Fill="{DynamicResource PrimaryDarkBrush}" />
                    <Ellipse x:Name="Dot1" Width="8" Height="8" Margin="4,0" Fill="{DynamicResource SkyBorderBrush}" />
                    <Ellipse x:Name="Dot2" Width="8" Height="8" Margin="4,0" Fill="{DynamicResource SkyBorderBrush}" />
                    <Ellipse x:Name="Dot3" Width="8" Height="8" Margin="4,0" Fill="{DynamicResource SkyBorderBrush}" />
                    <Ellipse x:Name="Dot4" Width="8" Height="8" Margin="4,0" Fill="{DynamicResource SkyBorderBrush}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BackButton"
                            Style="{StaticResource SubtleButton}"
                            Click="OnBackClick"
                            Padding="22,12"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,10,0"
                            Visibility="Collapsed" />
                    <Button x:Name="NextButton"
                            Style="{StaticResource PrimaryButton}"
                            Click="OnNextClick"
                            Padding="28,12"
                            FontSize="14"
                            FontWeight="SemiBold" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
