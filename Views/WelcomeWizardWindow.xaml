<Window x:Class="EduGuardAgent.Views.WelcomeWizardWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Guardi"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        Background="{StaticResource PageGradient}">
    <Grid>
    <Border Background="{StaticResource CardBrush}"
            CornerRadius="24"
            Padding="40,34"
            MinWidth="440"
            MaxWidth="500"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BorderBrush="{StaticResource SkyBorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#0369A1"
                              BlurRadius="32"
                              ShadowDepth="0"
                              Opacity="0.35" />
        </Border.Effect>

        <StackPanel>
            <Grid HorizontalAlignment="Center" Margin="0,0,0,12">
                <!-- Onboarding is always Trusted Sub — see WelcomeWizardWindow.xaml.cs constructor. -->
                <views:TrustedSubMascot Width="72" Height="82" />
            </Grid>

            <!-- Step 1: local vs online -->
            <StackPanel x:Name="ModeStep">
                <TextBlock x:Name="ModeTitleText"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryDarkBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="ModeSubtitleText"
                           FontSize="15"
                           Foreground="{StaticResource MutedBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,10,0,18" />

                <Button x:Name="LocalChoiceButton"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnChooseLocalClick"
                        Padding="18,14"
                        HorizontalContentAlignment="Stretch"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="LocalChoiceTitleText" FontWeight="Bold" FontSize="15" TextWrapping="Wrap" />
                        <TextBlock x:Name="LocalChoiceBodyText" FontSize="12" TextWrapping="Wrap" Opacity="0.85" Margin="0,3,0,0" />
                    </StackPanel>
                </Button>

                <Border CornerRadius="12"
                        BorderBrush="{StaticResource SkyBorderBrush}"
                        BorderThickness="1"
                        Padding="18,14"
                        Opacity="0.55"
                        IsHitTestVisible="False">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="OnlineChoiceTitleText" FontWeight="Bold" FontSize="15" Foreground="{StaticResource PrimaryDarkBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="OnlineChoiceBodyText" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="{StaticResource SkyBorderBrush}"
                                CornerRadius="999"
                                Padding="10,4"
                                VerticalAlignment="Top"
                                Margin="10,0,0,0">
                            <TextBlock x:Name="OnlineBadgeText" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryDarkBrush}" />
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Step 2: name -->
            <StackPanel x:Name="NameStep" Visibility="Collapsed">
                <TextBlock x:Name="NameTitleText"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryDarkBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="NamePromptText"
                           FontSize="15"
                           Foreground="{StaticResource MutedBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,10,0,16" />

                <TextBox x:Name="NameInput"
                         MaxLength="32"
                         FontSize="20"
                         Padding="12,10"
                         HorizontalContentAlignment="Center"
                         Margin="0,0,0,8"
                         KeyDown="OnNameKeyDown" />

                <TextBlock x:Name="NameErrorText"
                           Foreground="{StaticResource WarningBrush}"
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MinHeight="20"
                           Margin="0,0,0,16"
                           Visibility="Collapsed" />

                <Button x:Name="NameConfirmButton"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnNameConfirmClick"
                        Padding="28,12"
                        FontSize="14"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Step 3: PIN (local setup only) -->
            <StackPanel x:Name="PinStep" Visibility="Collapsed">
                <TextBlock x:Name="PinTitleText"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryDarkBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="PinPromptText"
                           FontSize="15"
                           Foreground="{StaticResource MutedBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,10,0,16" />

                <PasswordBox x:Name="PinInput"
                             MaxLength="8"
                             FontSize="22"
                             Padding="12,10"
                             HorizontalContentAlignment="Center"
                             Margin="0,0,0,8"
                             KeyDown="OnPinKeyDown" />

                <TextBlock x:Name="PinErrorText"
                           Foreground="{StaticResource WarningBrush}"
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MinHeight="20"
                           Margin="0,0,0,16"
                           Visibility="Collapsed" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="PinSkipButton"
                            Style="{StaticResource SubtleButton}"
                            Click="OnPinSkipClick"
                            Padding="22,12"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,0,10,0" />
                    <Button x:Name="PinConfirmButton"
                            Style="{StaticResource PrimaryButton}"
                            Click="OnPinConfirmClick"
                            Padding="22,12"
                            FontSize="14"
                            FontWeight="SemiBold" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
    </Grid>
</Window>
