<Window x:Class="EduGuardAgent.Views.LockOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Locked"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        Background="{StaticResource LockOverlayGradient}">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainContent"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.6">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="MainScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.95" To="1" Duration="0:0:0.6">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="MainScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.95" To="1" Duration="0:0:0.6">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="FloatTransform"
                                     Storyboard.TargetProperty="Y"
                                     From="-8" To="8" Duration="0:0:3"
                                     AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <ScrollViewer x:Name="MainContent"
                  Opacity="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="40,32">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MaxWidth="720"
                    Margin="0,24">
            <StackPanel.LayoutTransform>
                <ScaleTransform x:Name="MainScale" ScaleX="1" ScaleY="1" />
            </StackPanel.LayoutTransform>

            <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="FloatTransform" Y="0" />
                </Grid.RenderTransform>
                <views:GuardiMascot Width="130"
                                    Height="148"
                                    Visibility="{Binding ShowLockMascotGuardi, Converter={StaticResource BoolToVisibility}}" />
                <views:TrustedSubMascot Width="130"
                                    Height="148"
                                    Visibility="{Binding ShowLockMascotTrustedSub, Converter={StaticResource BoolToVisibility}}" />
                <views:RestrictedSubMascot Width="130"
                                    Height="148"
                                    Visibility="{Binding ShowLockMascotRestrictedSub, Converter={StaticResource BoolToVisibility}}" />
                <views:BedtimeMoonIcon Width="130"
                                       Height="130"
                                       Visibility="{Binding ShowLockMoonIcon, Converter={StaticResource BoolToVisibility}}" />
            </Grid>

            <TextBlock Text="{Binding LockOverlayHeadline, Mode=OneWay}"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="{StaticResource OnPrimaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       LineHeight="42" />

            <TextBlock Text="{Binding LockOverlayBody, Mode=OneWay}"
                       FontSize="18"
                       Foreground="{StaticResource OnPrimaryMutedBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       LineHeight="26"
                       Margin="0,20,0,28" />

            <Border Background="{StaticResource GlassCardBrush}"
                    BorderBrush="{StaticResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="24,20"
                    HorizontalAlignment="Stretch"
                    MaxWidth="420"
                    Visibility="{Binding ShowLockScreenTimeStats, Converter={StaticResource BoolToVisibility}}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="24"
                                      ShadowDepth="4"
                                      Opacity="0.15" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{Binding LockOverlayStatsLabel, Mode=OneWay}"
                               Foreground="{StaticResource OnPrimaryMutedBrush}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                    <TextBlock Text="{Binding ScreenTimeLimit, Mode=OneWay}"
                               Foreground="{StaticResource OnPrimaryBrush}"
                               FontSize="36"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Background="{StaticResource GlassCardBrush}"
                    BorderBrush="{StaticResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="24,20"
                    HorizontalAlignment="Stretch"
                    MaxWidth="420"
                    Visibility="{Binding ShowBedtimeCountdown, Converter={StaticResource BoolToVisibility}}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="24"
                                      ShadowDepth="4"
                                      Opacity="0.15" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{Binding BedtimeCountdownLabel, Mode=OneWay}"
                               Foreground="{StaticResource OnPrimaryMutedBrush}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                    <TextBlock Text="{Binding BedtimeUnlockCountdown, Mode=OneWay}"
                               Foreground="{StaticResource OnPrimaryBrush}"
                               FontSize="44"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               FontFamily="Consolas, Cascadia Mono, Segoe UI, monospace" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding LockOverlayFooter, Mode=OneWay}"
                       Foreground="{StaticResource OnPrimaryMutedBrush}"
                       FontSize="14"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       LineHeight="22"
                       Margin="0,28,0,0" />

            <Button Content="{Binding LockOverlayDismissLabel, Mode=OneWay}"
                    Style="{StaticResource GhostButton}"
                    Command="{Binding DismissLockOverlayCommand}"
                    Margin="0,32,0,0"
                    Padding="28,14"
                    FontSize="16"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    Visibility="{Binding ShowLockDismissButton, Converter={StaticResource BoolToVisibility}}" />

            <TextBlock Text="{Binding LockOverlayDismissHint, Mode=OneWay}"
                       Foreground="{StaticResource OnPrimaryBrush}"
                       Opacity="0.82"
                       FontSize="12"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       LineHeight="18"
                       Margin="0,10,0,0"
                       Visibility="{Binding ShowLockDismissButton, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>
    </ScrollViewer>
</Window>
