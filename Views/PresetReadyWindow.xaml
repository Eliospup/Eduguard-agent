<Window x:Class="EduGuardAgent.Views.PresetReadyWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Guardi"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        Background="{StaticResource PageGradient}">
    <Grid>
    <Border Background="{StaticResource CardBrush}"
            CornerRadius="24"
            Padding="40,34"
            MinWidth="440"
            MaxWidth="500"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BorderBrush="{StaticResource SkyBorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#0369A1"
                              BlurRadius="32"
                              ShadowDepth="0"
                              Opacity="0.35" />
        </Border.Effect>

        <StackPanel>
            <Grid HorizontalAlignment="Center" Margin="0,0,0,12">
                <views:TrustedSubMascot Width="72" Height="82" />
            </Grid>

            <TextBlock x:Name="HeadlineText"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryDarkBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />

            <TextBlock x:Name="BodyText"
                       FontSize="15"
                       Foreground="{StaticResource MutedBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,14,0,24" />

            <Button x:Name="GotItButton"
                    Content="Got it!"
                    Click="OnGotItClick"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Background="{StaticResource AccentBrush}"
                    BorderThickness="0"
                    Padding="28,12"
                    HorizontalAlignment="Center"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="12" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Border>
    </Grid>
</Window>
