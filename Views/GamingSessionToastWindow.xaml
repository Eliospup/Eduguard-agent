<Window x:Class="EduGuardAgent.Views.GamingSessionToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game session"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="212"
        SizeToContent="Height"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">
    <Border Background="{StaticResource CardBrush}"
            CornerRadius="10"
            Padding="16,14"
            BorderBrush="{StaticResource SkyBorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#0369A1"
                              BlurRadius="14"
                              ShadowDepth="3"
                              Opacity="0.28" />
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center">
            <TextBlock x:Name="IconText"
                       FontSize="28"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" />

            <TextBlock x:Name="TitleText"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryDarkBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />

            <TextBlock x:Name="MessageText"
                       FontSize="12"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,6,0,0"
                       LineHeight="16" />
        </StackPanel>
    </Border>
</Window>
