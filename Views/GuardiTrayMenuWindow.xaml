<Window x:Class="EduGuardAgent.Views.GuardiTrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Guardi"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="True">
    <Border Background="{StaticResource CardBrush}"
            CornerRadius="18"
            Padding="14"
            MinWidth="260"
            BorderBrush="{StaticResource SkyBorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#0369A1"
                              BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.32" />
        </Border.Effect>

        <StackPanel>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <views:GuardiMascot x:Name="Mascot"
                                    Width="44"
                                    Height="50"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center" />
                <Border x:Name="ShieldHost"
                        Width="40"
                        Height="40"
                        CornerRadius="12"
                        Background="{StaticResource AccentBrush}"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                    <views:GuardiShieldIcon Width="24"
                                            Height="28"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               Text="Guardi"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryDarkBrush}" />
                    <TextBlock x:Name="SubtitleText"
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>

            <Border Height="1"
                    Background="{StaticResource GlassDividerBrush}"
                    Margin="0,0,0,8" />

            <Button x:Name="OpenButton"
                    Style="{StaticResource SettingsRowButton}"
                    Click="OnOpenClick"
                    Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🛡️"
                               FontSize="18"
                               VerticalAlignment="Center"
                               Margin="16,0,12,0" />
                    <TextBlock Grid.Column="1"
                               x:Name="OpenLabel"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryDarkBrush}"
                               Margin="0,0,16,0" />
                </Grid>
            </Button>

            <Button x:Name="QuitButton"
                    Style="{StaticResource SettingsRowButton}"
                    Click="OnQuitClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="⏻"
                               FontSize="18"
                               VerticalAlignment="Center"
                               Margin="16,0,12,0" />
                    <TextBlock Grid.Column="1"
                               x:Name="QuitLabel"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,0,16,0" />
                </Grid>
            </Button>
        </StackPanel>
    </Border>
</Window>
