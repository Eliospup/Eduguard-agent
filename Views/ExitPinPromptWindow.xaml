<Window x:Class="EduGuardAgent.Views.ExitPinPromptWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Dom PIN"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        ShowInTaskbar="False">
    <Border Background="{StaticResource CardBrush}"
            CornerRadius="20"
            Padding="32,28"
            MinWidth="380"
            MaxWidth="440"
            BorderBrush="{StaticResource SkyBorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#0369A1"
                              BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.35" />
        </Border.Effect>

        <StackPanel>
            <Grid HorizontalAlignment="Center" Margin="0,0,0,12">
                <views:GuardiMascot x:Name="Mascot" Width="72" Height="82" />
                <views:TrustedSubMascot x:Name="TrustedSubMascotIcon" Width="72" Height="82" />
                <views:RestrictedSubMascot x:Name="RestrictedSubMascotIcon" Width="72" Height="82" />
            </Grid>

            <TextBlock x:Name="TitleText"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryDarkBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />

            <TextBlock x:Name="PromptText"
                       FontSize="15"
                       Foreground="{StaticResource MutedBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,10,0,16" />

            <PasswordBox x:Name="PinInput"
                         MaxLength="8"
                         FontSize="22"
                         Padding="12,10"
                         HorizontalContentAlignment="Center"
                         Margin="0,0,0,8"
                         KeyDown="OnPinKeyDown" />

            <TextBlock x:Name="ErrorText"
                       Foreground="{StaticResource WarningBrush}"
                       FontSize="13"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MinHeight="20"
                       Margin="0,0,0,16"
                       Visibility="Collapsed" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="CancelButton"
                        Style="{StaticResource SubtleButton}"
                        Click="OnCancelClick"
                        Padding="22,12"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Margin="0,0,10,0" />
                <Button x:Name="ConfirmButton"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnConfirmClick"
                        Padding="22,12"
                        FontSize="14"
                        FontWeight="SemiBold" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
