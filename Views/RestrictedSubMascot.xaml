<UserControl x:Class="EduGuardAgent.Views.RestrictedSubMascot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             SnapsToDevicePixels="True">
    <Grid>
      <Viewbox x:Name="VectorFallback" Stretch="Uniform"
             Width="{Binding ElementName=Root, Path=Width}"
             Height="{Binding ElementName=Root, Path=Height}">
        <Canvas Width="120" Height="136">
            <Ellipse Canvas.Left="28" Canvas.Top="122" Width="64" Height="10" Fill="#22000000" />

            <!-- Shackle -->
            <Path Stroke="#E0941A"
                  StrokeThickness="14"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Fill="{x:Null}"
                  Data="M40,54 L40,36 A20,20 0 1 1 80,36 L80,54" />
            <Path Stroke="#F7C877"
                  StrokeThickness="4"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Opacity="0.6"
                  Fill="{x:Null}"
                  Data="M40,54 L40,36 A20,20 0 1 1 80,36 L80,54" />

            <!-- Body -->
            <Rectangle Canvas.Left="20" Canvas.Top="46" Width="80" Height="78" RadiusX="22" RadiusY="22" Fill="#F5A623" />
            <Rectangle Canvas.Left="28" Canvas.Top="54" Width="64" Height="62" RadiusX="16" RadiusY="16" Fill="#FFD9A0" Opacity="0.25" />

            <!-- Face -->
            <Ellipse Canvas.Left="40" Canvas.Top="64" Width="16" Height="18" Fill="White" />
            <Ellipse Canvas.Left="64" Canvas.Top="64" Width="16" Height="18" Fill="White" />
            <Ellipse Canvas.Left="46" Canvas.Top="71" Width="7" Height="7" Fill="#2B2114" />
            <Ellipse Canvas.Left="70" Canvas.Top="71" Width="7" Height="7" Fill="#2B2114" />
            <Ellipse Canvas.Left="48" Canvas.Top="69" Width="3" Height="3" Fill="White" />
            <Ellipse Canvas.Left="72" Canvas.Top="69" Width="3" Height="3" Fill="White" />

            <Ellipse Canvas.Left="32" Canvas.Top="82" Width="12" Height="7" Fill="#FFD9A0" Opacity="0.8" />
            <Ellipse Canvas.Left="76" Canvas.Top="82" Width="12" Height="7" Fill="#FFD9A0" Opacity="0.8" />

            <Path Stroke="White"
                  StrokeThickness="3.5"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Data="M42,93 Q60,109 78,93" />
        </Canvas>
      </Viewbox>
      <Image x:Name="PngImage" Stretch="Uniform" Visibility="Collapsed" />
    </Grid>
</UserControl>
