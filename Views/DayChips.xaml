<UserControl x:Class="EduGuardAgent.Views.DayChips"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
  <UserControl.Resources>
    <Style x:Key="DayChipToggle" TargetType="ToggleButton">
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="Chip"
                    CornerRadius="14"
                    Padding="13,6"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource SkyBorderBrush}"
                    BorderThickness="1">
              <TextBlock x:Name="ChipText"
                         Text="{TemplateBinding Content}"
                         Foreground="{DynamicResource MutedBrush}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chip" Property="BorderBrush" Value="{DynamicResource PrimaryDarkBrush}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource SegmentActiveBrush}" />
                <Setter TargetName="Chip" Property="BorderBrush" Value="{DynamicResource SegmentActiveBrush}" />
                <Setter TargetName="ChipText" Property="Foreground" Value="{DynamicResource SegmentActiveForegroundBrush}" />
                <Setter TargetName="ChipText" Property="FontWeight" Value="SemiBold" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <WrapPanel x:Name="ChipPanel" Orientation="Horizontal" />
</UserControl>
