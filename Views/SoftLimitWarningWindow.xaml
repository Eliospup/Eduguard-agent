<Window x:Class="EduGuardAgent.Views.SoftLimitWarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EduGuardAgent.Views"
        Title="Guardi"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        Closing="OnClosing"
        Background="{StaticResource PageGradient}">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainContent"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <ScrollViewer x:Name="MainContent"
                  Opacity="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="40,32">
        <Border Background="{StaticResource CardBrush}"
                CornerRadius="24"
                Padding="44,38"
                MaxWidth="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{StaticResource SkyBorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#0369A1"
                                  BlurRadius="32"
                                  ShadowDepth="0"
                                  Opacity="0.35" />
            </Border.Effect>

            <StackPanel>
                <views:TrustedSubMascot Width="96" Height="110" HorizontalAlignment="Center" Margin="0,0,0,16" />

                <TextBlock Text="{Binding SoftLimitWarningTitle}"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryDarkBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />

                <TextBlock Text="{Binding SoftLimitWarningBody}"
                           FontSize="15"
                           Foreground="{StaticResource MutedBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           Margin="0,14,0,0" />

                <TextBlock Text="{Binding SoftLimitWarningFooter}"
                           FontSize="12"
                           Foreground="{StaticResource MutedBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Opacity="0.85"
                           Margin="0,18,0,26" />

                <Button Content="{Binding SoftLimitWarningContinueLabel}"
                        Style="{StaticResource SubtleButton}"
                        Command="{Binding ContinueSoftLimitAnywayCommand}"
                        Click="OnContinueClick"
                        Padding="22,12"
                        FontSize="13"
                        Opacity="0.75"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>
